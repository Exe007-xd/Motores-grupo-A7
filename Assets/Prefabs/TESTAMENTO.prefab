--- !u!114 &2078626721052008572
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2571648571829534152}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u201CPara Mart\xEDn D\u2019Angelo:\r\n\r\nPor medio de la presente, en
    mi car\xE1cter de representante legal y ejecutor testamentario, dej\xF3 constancia
    de la transferencia de dominio de la propiedad ubicada en zona rural a favor
    del heredero designado.\r\nSe certifica que el causante, en pleno uso de sus
    facultades, ha establecido de manera inequ\xEDvoca que el destinatario de la
    presente es el \xFAnico heredero leg\xEDtimo de la totalidad de sus bienes, sin
    concurrencia de terceros.\r\nAsimismo, se deja constancia de que el inmueble
    ha permanecido en posesi\xF3n de la familia a lo largo de m\xFAltiples generaciones,
    con registros que se remontan a la \xE9poca colonial.\r\nLa propiedad se entrega
    en su estado actual, junto con todos los bienes y elementos contenidos en su
    interior. El heredero acepta la totalidad de la herencia, incluyendo toda carga,
    obligaci\xF3n o circunstancia asociada, conocida o no al momento de la firma.\r\nSe
    recomienda abstenerse de realizar modificaciones estructurales sin una inspecci\xF3n
    previa completa, especialmente en el \xE1rea del s\xF3tano.\r\n\r\nSin otro particular,\r\n\r\nFirma
    Samuel Memphis\r\nEjecutor Testamentario\u201D\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
