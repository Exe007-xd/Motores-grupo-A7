--- !u!114 &527439867997681873
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 423058815780452915}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\r\n\u201CMartin, querido sobrino:\r\n\r\nTe dejo esta carta y la casa
    porque creo que sos lo suficientemente inteligente como para descubrir aquello
    que nos persigue.\r\nHubiera querido compartir m\xE1s tiempo con vos. Tomar unos
    mates, conversar durante horas, compartir comidas, risas, discusiones y hasta
    tristezas\u2026 pero nuestra familia carga con una maldici\xF3n desde hace generaciones,
    y esta vez me toc\xF3 a m\xED. Ya se llev\xF3 a muchos antes.\r\nDurante a\xF1os
    investigu\xE9 por mi cuenta. Viaj\xE9, revis\xE9 documentos viejos y segu\xED
    pistas que otros prefirieron ignorar, intentando descubrir d\xF3nde comenz\xF3
    todo. S\xE9 que este mal es tan antiguo como la llegada de nuestros antepasados
    en 1776, cuando se asentaron por primera vez en estas tierras.\r\nEncontr\xE9
    algunos detalles m\xE1s\u2026 cosas que preferir\xEDa contarte en persona, pero
    temo no tener ya el tiempo suficiente.\r\n\r\nSi est\xE1s leyendo esto, significa
    que probablemente yo ya no est\xE9.\r\n\r\nY si ese es el caso\u2026 entonces
    tambi\xE9n significa que posiblemente comenzar\xE1 a buscarte a vos.\r\n\r\nAtte:    
    icolas D\u2019Angelo\u201D"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
